# Zoning Review Platform local environment
# Copy to `.env` in the repo root and fill in real values.

# Web frontend
# Local development defaults to http://localhost:8000 when unset.
# Set VITE_API_URL explicitly for deployed environments.
VITE_API_URL=http://localhost:8000

# API browser access
APP_ENV=local
# For production, lock this to the deployed Vercel frontend origin.
CORS_ALLOW_ORIGINS=http://localhost:5173
# Source-admin key. When set, source write/reindex/import routes require
# X-Admin-Access-Key. Source list/status remain available to authenticated users.
ADMIN_ACCESS_KEY=

# API storage
# Render staging/production should set DATABASE_URL in the Render dashboard.
# Supabase session pooler shape:
# postgresql://postgres.<PROJECT_REF>:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=
# Local fallback only. Do not use ZONING_DB_PATH for Render staging/production.
ZONING_DB_PATH=apps/api/app/data/app.sqlite3
# Legacy fallback only; prefer ZONING_DB_PATH for new setups.
# IBM_ZONING_DB_PATH=apps/api/app/data/app.sqlite3

# AI/RAG providers
# Local dev default runs deterministic analysis + source-registry retrieval
# so the API works with zero external credentials.
AI_PROVIDER=deterministic
RAG_PROVIDER=source_registry
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_PROVIDER=none
# Warm and repair the source/chunk/vector indexes during API startup.
STARTUP_REINDEX_ENABLED=true

# Production AI provider (set AI_PROVIDER=openai to use)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=20

# Analysis-provider failover (production resilience). When the primary analysis
# provider (AI_PROVIDER) exhausts its retries (e.g. a sustained 429), the ordered
# fallback providers below are tried in turn. Each is OpenAI-compatible and uses a
# separate account, so an independent rate limit keeps the API answering.
# Leave AI_PROVIDER_FALLBACKS empty to disable (the eval gate never sets it, so it
# always runs against a single pinned provider for reproducibility).
# AI_PROVIDER_FALLBACKS=cerebras,openrouter
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama-3.3-70b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_TIMEOUT_SECONDS=20
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TIMEOUT_SECONDS=20

# Production vector store (set VECTOR_PROVIDER=qdrant + RAG_PROVIDER=hybrid_local + EMBEDDING_PROVIDER=openai)
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=
# QDRANT_COLLECTION=zoning_source_chunks

# Optional OpenAI-compatible local model support
# Select with AI_PROVIDER=local. Works with local servers such as Ollama,
# vLLM, llama.cpp server, LM Studio, or TGI when they expose chat completions.
# LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL_NAME=llama3.1:8b
# LOCAL_MODEL_TIMEOUT_SECONDS=60
# LOCAL_MODEL_API_KEY=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_TIMEOUT_SECONDS=8
# GOOGLE_DISTRICT_KEYWORD_MAP={"downtown":"mixed-use-core","industrial":"industrial-zone"}

# Supabase (required for public-beta auth; set AUTH_PROVIDER=supabase on the API)
# Frontend vars (build-time)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=
# Backend vars (runtime) — set these on Render
# SUPABASE_PROJECT_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=          # Project Settings > API > anon/public key; sent as apikey header when fetching JWKS
# SUPABASE_JWT_SECRET=        # Fallback for HS256 tokens; ES256 (current default) doesn't need this
# AUTH_PROVIDER=supabase
# AUTH_REQUIRED=true

# Observability
# SENTRY_DSN=
# VITE_SENTRY_DSN=
