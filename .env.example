# Zoning Agent Platform local environment
# Copy to `.env` in the repo root and fill in real values.

# Web frontend
# Local development defaults to http://localhost:8000 when unset.
# Set VITE_API_URL explicitly for deployed environments.
VITE_API_URL=http://localhost:8000

# API browser access
# For Vercel, set this in the API host to your deployed URL.
# Use "*" only for quick smoke tests.
CORS_ALLOW_ORIGINS=http://localhost:5173

# API storage
ZONING_DB_PATH=apps/api/app/data/app.sqlite3
# Legacy fallback only; prefer ZONING_DB_PATH for new setups.
# IBM_ZONING_DB_PATH=apps/api/app/data/app.sqlite3

# AI/RAG providers
# Defaults are local and do not require IBM watsonx credentials.
AI_PROVIDER=deterministic
RAG_PROVIDER=source_registry
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=text-embedding-3-small

# Optional OpenAI provider support
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=20

# Google Maps Platform
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_TIMEOUT_SECONDS=8
# GOOGLE_DISTRICT_KEYWORD_MAP={"downtown":"mixed-use-core","industrial":"industrial-zone"}

# Optional legacy IBM watsonx.ai support
# Prefer AI_PROVIDER/RAG_PROVIDER. This compatibility flag selects WatsonX
# providers when set to true and explicit provider variables are not set.
# WATSONX_ENABLED=false
WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_PLATFORM_URL=https://api.dataplatform.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_VECTOR_INDEX_ID=
# Example model id; replace with one enabled in your watsonx project.
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
WATSONX_TIMEOUT_SECONDS=20
# WATSONX_MAX_ATTEMPTS=3
# WATSONX_RETRY_DELAY_SECONDS=0.6
